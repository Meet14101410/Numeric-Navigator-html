body{
  font-family: Arial;
  text-align: center;
  background: #f0f8ff;
}

h2{
  color: #2c3e50;
}

input{
  padding: 8px;
  font-size: 16px;
  margin: 10px;
}

button{
  padding: 8px 15px;
  background: #3498db;
  color: white;
  border: none;
  cursor: pointer;
}

button:hover{
  background: #2980b9;
}

#result{
  font-weight: bold;
  margin-top: 10px;
}
